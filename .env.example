# Настройки подключения к базе данных PostgreSQL (для Docker-compose хост - db)
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Настройки безопасности и JWT-токенов
SECRET_KEY=your_secret_key_for_jwt_tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

ADMIN_SECRET_KEY=super-secret-admin-key

# Настройки Celery и Redis (для Docker-compose хост - redis)
CELERY_BROKER_URL=redis://redis:6379/0